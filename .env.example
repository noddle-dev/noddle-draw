# noddle — mọi biến đều TUỲ CHỌN: không cấu hình gì app vẫn chạy
# (file storage, AI tắt). Copy thành .env rồi điền thứ bạn cần.

# Host port cho docker compose (mặc định 8000)
#NODDLE_PORT=8000

# Postgres — docker compose tự set sẵn; chỉ cần khi chạy backend ngoài Docker.
# Không có → dữ liệu lưu file trong backend/storage/
#DATABASE_URL=postgresql://noddle:noddle@127.0.0.1:5432/noddle

# CORS allowlist cho dev tooling (prod là same-origin, không cần)
#NODDLE_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# ---- AI pool dùng chung (TUỲ CHỌN — hầu hết self-hoster bỏ qua) ------------
# Người dùng tự mang key AI của họ trong app (BYOK, lưu ở trình duyệt, gửi
# per-request — server không lưu). Chỉ set các biến này nếu bạn muốn tài trợ
# một pool AI chung cho mọi khách.
#DATABRICKS_HOST=
#DATABRICKS_TOKEN=
#DATABRICKS_CONFIG_PROFILE=
#DATABRICKS_CLAUDE_ENDPOINT=

# ---- Object storage S3/R2 cho log shipping (TUỲ CHỌN) ----------------------
#S3_ENDPOINT_URL=
#S3_BUCKET=
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=
#S3_REGION=auto
