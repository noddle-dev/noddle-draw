# noddle — every variable is OPTIONAL: with zero config the app still runs
# (file storage, AI off). Copy to .env and fill in what you need.

# Host port for docker compose (default 8000)
#NODDLE_PORT=8000

# Postgres — docker compose sets this itself; only needed when running the
# backend outside Docker. Absent → data persists to backend/storage/ files.
#DATABASE_URL=postgresql://noddle:noddle@127.0.0.1:5432/noddle

# CORS allowlist for dev tooling (prod is same-origin, not needed)
#NODDLE_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# ---- Shared AI pool (OPTIONAL — most self-hosters skip this) ---------------
# Users bring their own AI key in the app (BYOK, stored in their browser and
# sent per-request — the server never stores it). Only set these if you want
# to sponsor a shared AI pool for all visitors.
#DATABRICKS_HOST=
#DATABRICKS_TOKEN=
#DATABRICKS_CONFIG_PROFILE=
#DATABRICKS_CLAUDE_ENDPOINT=

# ---- S3/R2 object storage for log shipping (OPTIONAL) ----------------------
#S3_ENDPOINT_URL=
#S3_BUCKET=
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=
#S3_REGION=auto
