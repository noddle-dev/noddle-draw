# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Everything is OPTIONAL — with an empty .env the app boots in guest mode with
# file storage and AI endpoints answering 503 (graceful degradation).

# ── AI generation (Claude on Databricks Model Serving) ─────────────────────
# Enable with ONE of the two auth methods below.
# Method 1: PAT
# DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
# DATABRICKS_TOKEN=dapi...
# Method 2: profile from ~/.databrickscfg (PAT or OAuth M2M client_id/secret —
# the secret stays in the profile file, never here)
# DATABRICKS_CONFIG_PROFILE=my-profile
# DATABRICKS_CONFIG_FILE=~/.databrickscfg          # only if not the default path
# Serving-endpoint NAME (not a model id); default: databricks-claude-opus-4-8
# DATABRICKS_CLAUDE_ENDPOINT=databricks-claude-opus-4-8

# ── SSO — generic OIDC (ADR-0003): Google / Entra ID / Keycloak / Okta ─────
# For Google: create an OAuth 2.0 Client ID (Web application) in Google Cloud
# Console with redirect URI  {app-origin}/api/auth/oidc/callback
# All three set => the "Sign in with SSO" button appears automatically.
OIDC_ISSUER=https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Set explicitly when running behind a reverse proxy (else derived per request):
# OIDC_REDIRECT_URL=https://noddle.example/api/auth/oidc/callback

# ── Storage ─────────────────────────────────────────────────────────────────
# Optional Postgres persistence — set to switch storage from files to Postgres.
# Unset or unreachable => file storage fallback (warning logged, no boot crash).
# docker-compose.yml wires this to its bundled `db` service automatically.
# DATABASE_URL=postgresql://user:pass@host:5432/noddle

# ── Object storage (S3-compatible: Backblaze B2 or Cloudflare R2) ───────────
# Rotated audit/ai_usage log segments ship here (services/object_storage.py);
# also used by scripts/db_backup/. Absent => local-only, no errors.
# B2 endpoint: https://s3.<region>.backblazeb2.com (region auto-derived).
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Security / hardening ────────────────────────────────────────────────────
# CORS allowlist, comma-separated. Default: http://localhost:8000 — never "*".
# NODDLE_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173
# Admin key for the games kill-switch endpoints (default: noddle-admin).
# NODDLE_ADMIN_KEY=change-me
# Obfuscation key for BYOK AI keys at rest (mockup XOR — NOT real encryption;
# replace with KMS before production).
# NODDLE_AI_KEY_SECRET=change-me-too

# ── Companion script (send_teams_alert.py) ──────────────────────────────────
# Power Automate "HTTP POST URL" for the Teams flow (from the HTTP-request
# trigger). Contains a secret SAS token — treat as a credential.
# TEAMS_WEBHOOK_URL=https://prod-XX.<region>.logic.azure.com:443/workflows/<id>/triggers/manual/paths/invoke?...

# ── MCP server (mcp/noddle_mcp.py — read by the MCP process, not the backend) ─
# NODDLE_BASE_URL=http://127.0.0.1:8000
# NODDLE_TOKEN=noddle_...        # create in the app: profile → API tokens
